# Mapbox public access token — used at runtime for satellite tiles
# Lock to your Vercel domain in the Mapbox dashboard before sharing the install link.
NEXT_PUBLIC_MAPBOX_TOKEN=pk.replace-me

# Used at build time by scripts/generate-static-maps.ts to pregenerate offline hole maps.
# Can be the same token as NEXT_PUBLIC_MAPBOX_TOKEN.
MAPBOX_TOKEN=pk.replace-me
